NODE_NAME=us
HAPPY_NODE_ID=happy-us
HAPPY_NODE_REGION=us
PORT=3005
PUBLIC_URL=https://us-api.acdji.asia

# 两台节点必须完全一致
HANDY_MASTER_SECRET=replace-with-one-long-random-secret-for-both-nodes

# 共享数据库
DATABASE_URL=postgresql://happy:password@db.example.com:5432/happy

# 共享 Redis
REDIS_URL=redis://redis.example.com:6379

# 共享对象存储
S3_HOST=minio.example.com
S3_PORT=443
S3_USE_SSL=true
S3_REGION=us-east-1
S3_BUCKET=happy
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_PUBLIC_URL=https://files.example.com/happy
