NODE_NAME=us
HAPPY_NODE_ID=happy-us
HAPPY_NODE_REGION=us
PORT=3005
PUBLIC_URL=https://us-api.acdji.asia

# 两台节点必须完全一致
HANDY_MASTER_SECRET=replace-with-one-long-random-secret-for-both-nodes

# 共享数据库（建议放在美国节点）
DATABASE_URL=postgresql://happy:replace-with-postgres-password@42.48.172.229:5432/happy

# 共享 Redis（建议放在美国节点）
REDIS_URL=redis://:replace-with-redis-password@42.48.172.229:6379

# 共享对象存储（通过美国节点的 files.acdji.asia 访问）
S3_HOST=files.acdji.asia
S3_PORT=443
S3_USE_SSL=true
S3_REGION=us-east-1
S3_BUCKET=happy
S3_ACCESS_KEY=happyminio
S3_SECRET_KEY=replace-with-minio-password
S3_PUBLIC_URL=https://files.acdji.asia/happy
